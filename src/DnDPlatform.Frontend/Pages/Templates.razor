@page "/templates"
@inject NavigationManager navManager
@inject HttpClient Client
@inject IJSRuntime jsRuntime
@using System.Net.Http.Json
@using System.Text
@using System.Text.Json
@using System.ComponentModel.DataAnnotations
@using DnDPlatform.Frontend.Models.Entities;

<PageTitle>Templates</PageTitle>

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-4 text-primary">Templates</h1>
            <p class="lead text-muted">List your templates or create a new one</p>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-lg-6 mx-auto">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h5 class="mb-0" id="form-title">Add New Template</h5>
                </div>
                <div class="card-body">
                    <EditForm Model="@template" OnValidSubmit="@SubmitButton">
                        <DataAnnotationsValidator/>

                        <div class="mb-3">
                            <label for="Name" class="form-label">Template Name</label>
                            <InputText type="text" class="form-control" id="Name" name="Name"
                                placeholder="Enter template name" @bind-Value="template.Name"/>
                            <ValidationMessage For="@(() => template.Name)" />
                        </div>

                        <div class="mb-3">
                            <label for="System" class="form-label">System</label>
                            <InputText type="text" step="0.1" class="form-control" name="System"
                                placeholder="System (e.g. dnd5e)" @bind-Value="template.System"/>
                            <ValidationMessage For="@(() => template.System)" />
                        </div>

                        <div class="mb-3">
                            <label for="Fields" class="form-label">Fields</label>
                            <textarea type="text" step="0.1" class="form-control" id="Fields" name="Fields"
                                placeholder="Enter fields (must be in JSON format)" @bind="template.Fields"/>
                            <ValidationMessage For="@(() => template.Fields)" />
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <button type="submit" class="btn btn-primary">Save Template</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col text-center">
            <h2 class="mb-3">Templates</h2>
        </div>
    </div>
    @if(templates.Count() < 1) {
        <div class="row">
            <div class="col text-center py-5">
                <div class="text-muted">
                    <i class="bi bi-inbox" style="font-size: 4rem;"></i>
                    <h4 class="mt-3">No Templates Found...</h4>
                </div>
            </div>
        </div>
    }
    else {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (TemplateResponseModel temp in templates) {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title text-primary">@temp.name</h5>
                            <p class="card-text">
                                <strong>Template System:</strong> @temp.system<br>
                            </p>
                        </div>
                    </div>
                </div>
            }   
        </div>
    }
   
</div>


@code {
    private TemplateModel template {get;set;} = new();
    private List<TemplateResponseModel>? templates {get;set;} = new List<TemplateResponseModel>();
    private string _result = "";
    public async ValueTask<string?> GetFromLocalStorage(string key, string? defaultValue = null) => await jsRuntime.InvokeAsync<string>("localStorage.getItem", key) ?? defaultValue;
    private string? token = "";
    private async Task SubmitButton() {
        await createTemplateRequest();
        template = new TemplateModel();
        templates = await getTemplatesRequest();
    }

    private async Task createTemplateRequest() {
        var request = new HttpRequestMessage(HttpMethod.Post, "api/templates");
        var postBody = new {name = template.Name, system = template.System, jsonSchema = template.Fields};
        request.Content = new StringContent(JsonSerializer.Serialize(postBody), Encoding.UTF8, "application/json");
        request.Headers.Add("Authorization", $"Bearer {token}");
        using var response = await Client.SendAsync(request);
        if (response.IsSuccessStatusCode) {
            _result = await response.Content.ReadAsStringAsync();
        }
        else {
            _result = $"Error: {response.StatusCode}";
        } 
    } 

    private async Task<List<TemplateResponseModel>> getTemplatesRequest() {
        var request = new HttpRequestMessage(HttpMethod.Get, "api/templates");
        request.Headers.Add("Authorization", $"Bearer {token}");
        using var response = await Client.SendAsync(request);
        if (response.IsSuccessStatusCode) {
            string stream = await response.Content.ReadAsStringAsync();
            return JsonSerializer.Deserialize<List<TemplateResponseModel>>(stream);
        }
        else {
            _result = $"Error: {response.StatusCode}";
            return new List<TemplateResponseModel>();
        } 
    } 

    protected override async Task OnInitializedAsync()
    {
        token = await GetFromLocalStorage("token");
        templates = await getTemplatesRequest();
    } 
}