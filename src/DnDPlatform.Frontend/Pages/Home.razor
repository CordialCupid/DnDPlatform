@page "/"
@inject IJSRuntime jsRuntime
@inject HttpClient Client
@inject NavigationManager navManager
@inject DnDPlatform.Frontend.Services.LoginSingletonService loginService
@using System.Text.Json
@using System.Text
@using DnDPlatform.Frontend.Models.FormModels;

<PageTitle>Home</PageTitle>

<img src="/Photos/HomeBackground.png" class="background-image" alt="Tavern Background" />
<img src="/Photos/bartender.png" class="bartenderImage" alt="Bartender Image" />
<img src="/Photos/CounterBackground.png" class="backgroundCounter" alt="Tavern Bartop" />


@code {
    public async ValueTask<string?> GetFromLocalStorage(string key, string? defaultValue = null) => await jsRuntime.InvokeAsync<string>("localStorage.getItem", key) ?? defaultValue;
    private string token = "";
    protected override async Task OnInitializedAsync()
    {
        if(loginService.LoggedIn)
        {
            return;
        }
        else{
            navManager.NavigateTo("/register");
        }
    }
}