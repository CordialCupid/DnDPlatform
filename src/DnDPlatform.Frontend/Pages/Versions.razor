@page "/versions"
@inject NavigationManager navManager
@inject HttpClient Client
@inject IJSRuntime jsRuntime
@using System.Net.Http.Json
@using System.Text
@using System.Text.Json
@using System.ComponentModel.DataAnnotations
@using DnDPlatform.Frontend.Models.FormModels
@using DnDPlatform.Frontend.Models.ResponseModels
@using DnDPlatform.Frontend.Services

<PageTitle>Versions</PageTitle>

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col">
            <h1 class="display-4 fw-bold">Character Sheet Versions</h1>
            <p class="lead text-muted fw-lighter">Search by a Characters Id below to see the different version histories...</p>
        </div>
    </div>
    <div class="input-group">
            <span class="input-group-text clickable-hand" id="basic-addon1" @onclick="SubmitButton" >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-search" viewBox="0 0 16 16">
                    <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"></path>
                </svg>
            </span>
        <input @bind-value="enteredId" type="text" class="form-control" placeholder="Enter Character Id..." aria-label="Character Id Input" aria-describedby="character id input">
    </div>
    @if(versions.Count() > 0)
    {
        <button type="button" class="btn btn-dark mt-4" @onclick="(() => OpenDialog(ref _dialogOpenAdd))">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-person-plus" viewBox="0 0 16 16">
                <path d="M6 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6m2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0m4 8c0 1-1 1-1 1H1s-1 0-1-1 1-4 6-4 6 3 6 4m-1-.004c-.001-.246-.154-.986-.832-1.664C9.516 10.68 8.289 10 6 10s-3.516.68-4.168 1.332c-.678.678-.83 1.418-.832 1.664z"></path>
                <path fill-rule="evenodd" d="M13.5 5a.5.5 0 0 1 .5.5V7h1.5a.5.5 0 0 1 0 1H14v1.5a.5.5 0 0 1-1 0V8h-1.5a.5.5 0 0 1 0-1H13V5.5a.5.5 0 0 1 .5-.5"></path>
            </svg>
            Add Snapshot
        </button>
    }

    @if(versions.Count() < 1) {
        <div class="row">
            <div class="col text-center py-5">
                <div class="text-muted">
                    <i class="bi bi-inbox" style="font-size: 4rem;"></i>
                    <h4 class="mt-3">No Sheet Versions Found...</h4>
                    <p class="text-muted lead fw-lighter">Consider adding a new character or double checking the Id you entered</p>
                </div>
            </div>
        </div>
    }
    else {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mt-5">
            @foreach (VersionResponseModel sheet in versions) {
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        <div class="card-header bg-dark">
                            <h5 class="card-title text-white">@sheet.label</h5>
                        </div>
                        <div class="card-body">
                            <p class="card-text">
                                <strong>Sheet Version:</strong>@sheet.versionNumber<br>
                            </p>
                        </div>
                        <div class="card-footer bg-dark">
                            <div>
                                <button type="button" class="btn btn-secondary text-white rounded" style="border: none;" @onclick="((async) => OpenSheetDetails(sheet.id.ToString()))">Sheet Details</button>
                            </div>
                        </div>
                    </div>
                </div>
            }   
        </div>
    }
   
</div>

<div class="modal fade @_dialogCssForDetail" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-dark">
                <h1 class="modal-title fs-5 text-white" id="exampleModalLabel">Sheet Details</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" @onclick="() => CloseDialog(ref _dialogOpenDetail)"></button>
            </div>
            <div class="modal-body">
                <p>
                    <strong>Sheet Id:</strong> @_detailSheet.id
                </p>
            </div>
            <div class="modal-footer bg-dark">
                <button type="button" class="btn btn-secondary text-white" @onclick="() => CloseDialog(ref _dialogOpenDetail)">Close</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade @_dialogCssForAdd" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-dark">
                <h1 class="modal-title fs-5 text-white" id="exampleModalLabel">Add New Character Snapshot</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" @onclick="() => CloseDialog(ref _dialogOpenAdd)"></button>
            </div>
            <div class="modal-body">
                <div class="input-group">
                <input @bind-value="label" type="text" class="form-control" placeholder="Enter Snapshot Label..." aria-label="Character Id Input" aria-describedby="character id input">
            </div>
            </div>
            <div class="modal-footer bg-dark">
                <button type="button" class="btn btn-secondary text-white" @onclick="() => CloseDialog(ref _dialogOpenAdd)">Close</button>
                <button type="button" class="btn bg-white" @onclick="() => OnAddSnapshot()">Add</button>
            </div>
        </div>
    </div>
</div>


@code {
    private TemplateModel template {get;set;} = new();
    private VersionResponseModel _detailSheet {get;set;} = new();
    private List<VersionResponseModel> versions {get;set;} = new List<VersionResponseModel>();
    public async ValueTask<string?> GetFromLocalStorage(string key, string? defaultValue = null) => await jsRuntime.InvokeAsync<string>("localStorage.getItem", key) ?? defaultValue;
    private string? token = "";
    private string enteredId= "";
    private string label = "";
    private bool _dialogOpenDetail; 
    private string _dialogCssForDetail => _dialogOpenDetail ? "show" : "hide"; 
    private bool _dialogOpenAdd; 
    private string _dialogCssForAdd => _dialogOpenAdd ? "show" : "hide"; 
    private JsonDocument? templateSchema;
    
    private async Task SubmitButton() {
        if (!String.IsNullOrEmpty(enteredId))
        {
            var response = await GetVersionHistory(enteredId);
            if (response.IsSuccessStatusCode)
            {
                var stream = await response.Content.ReadAsStringAsync();
                versions = JsonSerializer.Deserialize<List<VersionResponseModel>>(stream) ?? new();
            }
        }
    }

    private Task OpenDialog(ref bool modalBool)
    {
        modalBool = true;
        return Task.CompletedTask;
    }

    private Task CloseDialog(ref bool modalBool)
    {
        modalBool = false;
        return Task.CompletedTask;
    }

    private async Task OpenSheetDetails(string? sheetId)
    {
        _detailSheet = versions.FirstOrDefault(t => t.id.ToString() == sheetId) ?? new();
        await OpenDialog(ref _dialogOpenDetail);
    }

    private async Task<HttpResponseMessage> GetVersionHistory(string id)
    {
        var request = new HttpRequestMessage(HttpMethod.Get, $"/api/characters/{id}/versions");
        request.Headers.Add("Authorization", $"Bearer {token}");
        var response = await Client.SendAsync(request);

        return response;
    }

    private async Task<HttpResponseMessage> AddSnapshot()
    {
        var request = new HttpRequestMessage(HttpMethod.Post, $"/api/characters/{enteredId}/snapshot");
        request.Headers.Add("Authorization", $"Bearer {token}");
        var response = await Client.SendAsync(request);

        return response;
    }

    private async Task OnAddSnapshot()
    {
        var response = await AddSnapshot();
        await CloseDialog(ref _dialogOpenAdd);
    }

    protected override async Task OnInitializedAsync()
    {
        if (LoginSingletonService.LoggedIn)
        {
            token = await GetFromLocalStorage("token");
        }
        else{
            navManager.NavigateTo("/register");
        }
    } 
}

<style>
    .show {
        display:block;
    }

    .hide {
        display: none;
    }

    
</style>